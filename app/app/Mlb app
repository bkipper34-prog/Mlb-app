  // Always fall through to local if API didn't stream anything
  if (!usedAPI) {
    const analysis = generateLocalAnalysis(prompt);
    const words = analysis.split(" ");
    for (let i=0; i<words.length; i++) {
      await new Promise(r=>setTimeout(r,25));
      setText(p=>p+(i===0?"": " ")+words[i]);
    }
  }
  setDone(true);
