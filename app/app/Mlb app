function LoadScreen({onDone,onData}) {
const [status,setStatus] = useState(“Loading today’s slate…”);
const [pct,setPct]       = useState(0);

useEffect(()=>{
// Load sample slate immediately, enter app, fetch live in background
const steps = [
[100,  “Connecting to MLB data feed…”],
[250,  “Loading projected pitchers…”],
[400,  “Loading HR targets…”],
[550,  “Running simulations…”],
[700,  “Calculating EV + Kelly…”],
[850,  “Ready ✓”],
];
steps.forEach(([delay, msg], i) => {
setTimeout(()=>{
setStatus(msg);
setPct(Math.round(((i+1)/steps.length)*100));
}, delay);
});
// Enter app after 1 second with sample slate
setTimeout(()=>{
onData(getSampleSlate());
onDone();
}, 1000);
},[]);

return(
<div style={{minHeight:“100vh”,background:”#000”,display:“flex”,flexDirection:“column”,alignItems:“center”,justifyContent:“center”,padding:32,fontFamily:”‘Inter’,sans-serif”}}>
