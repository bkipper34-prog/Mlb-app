// ── SCORING ──────────────────────────────────────────────────────────────────
function scoreK(p) {
const s = {
k:   Math.min(10, Math.max(0, ((p.kPct - 10) / 25) * 10)),
oK:  Math.min(10, Math.max(0, ((p.oppKPct - 14) / 18) * 10)),
csw: Math.min(10, Math.max(0, ((p.csw - 20) / 18) * 10)),
mix: Math.min(10, Math.max(1, p.pitchMix || 5)),
wh:  Math.min(10, Math.max(0, ((p.oppWhiff - 16) / 18) * 10)),
l5:  Math.min(10, Math.max(1, p.recentForm || 5)),
};
return Math.round((s.k*0.30 + s.oK*0.25 + s.csw*0.15 + s.mix*0.15 + s.wh*0.10 + s.l5*0.05) * 10);
}

function scoreHR(h) {
const s = {
bar: Math.min(10, Math.max(0, (h.barrel / 20) * 10)),
hh:  Math.min(10, Math.max(0, ((h.hardHit - 25) / 25) * 10)),
iso: Math.min(10, Math.max(0, (h.iso / 0.35) * 10)),
pfb: Math.min(10, Math.max(0, (h.pullFB / 25) * 10)),
hr9: Math.min(10, Math.max(0, (h.pitcherHR9 / 2.0) * 10)),
pw:  Math.min(10, Math.max(1, h.parkWeather || 5)),
rhr: Math.min(10, Math.max(1, h.recentHR || 5)),
};
return Math.round((s.bar*0.28 + s.hh*0.22 + s.iso*0.15 + s.pfb*0.15 + s.hr9*0.10 + s.pw*0.05 + s.rhr*0.05) * 10);
}

function simK(p, n=1000) {
const adj = (p.kPct/100) + ((p.oppKPct-22)/100)*0.3 + ((p.csw-28)/100)*0.2;
let res = [];
for (let i=0; i<n; i++) {
const u1=Math.random(), u2=Math.random();
const z = Math.sqrt(-2*Math.log(u1)) * Math.cos(2*Math.PI*u2);
const pa = Math.floor((80+Math.random()*25)/3.8);
res.push(Math.max(0, Math.round(Math.max(0.05, adj+z*0.06) * pa * (0.85+Math.random()*0.3))));
}
res.sort((a,b)=>a-b);
return { mean: res.reduce((s,v)=>s+v,0)/n, results:res, p25:res[Math.floor(n*0.25)], p50:res[Math.floor(n*0.50)], p75:res[Math.floor(n*0.75)] };
}

function simHR(h, n=1000) {
const pw = h.parkWeather || 5;
const base = (h.barrel/100)*0.55*(h.hardHit/100)*1.8*((pw-5)*0.04+1)*(h.pullFB/18);
let hits = 0;
for (let i=0; i<n; i++) {
const abs = 3+Math.floor(Math.random()*2);
for (let a=0; a<abs; a++) { if (Math.random()<base*(0.7+Math.random()*0.6)) { hits++; break; } }
}
return { prob:hits/n, hits, n };
}

function impliedProb(odds) { return odds<0 ? (-odds)/(-odds+100) : 100/(odds+100); }
function calcEV(prob, odds) {
const bp = impliedProb(odds);
const pay = odds>0 ? odds/100 : 100/(-odds);
return { ev:(prob*pay-(1-prob))*100, edge:(prob-bp)*100, bp };
}
function kellyCalc(prob, odds) {
const pay = odds>0 ? odds/100 : 100/(-odds);
const k = Math.max(0, (prob*pay-(1-prob))/pay);
return { full:k, quarter:k*0.25, units:+(k*0.25*10).toFixed(2) };
}

