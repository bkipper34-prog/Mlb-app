function buildSlate(raw) {
const pitchers = (raw.pitchers || []).map(p => {
const pf = getPF(p.park);
const data = {
…p,
parkFactor: pf,
pitchMix: Math.min(10, Math.max(1, (p.kPct||22)/3.2)),
recentForm: Math.min(10, Math.max(1, (p.kPct||22)/3.5)),
line: { dk: p.kLine||5.5, fd: p.kLine||5.5 },
openLine: { dk: p.kLine||5.5, fd: p.kLine||5.5 },
lineMoved: false,
ump: { name:“Today’s Ump”, kRate:”+0.0%”, favor:“Neutral” },
};
const score = scoreK(data);
const sim = simK(data, 1000);
const hitRate = sim.results.filter(k=>k>=data.line.dk).length/sim.results.length;
return { …data, score, sim, hitRate, evDK:calcEV(hitRate,-115), evFD:calcEV(hitRate,-110), kelly:kellyCalc(hitRate,-115), verdict:kVerdict(score) };
}).sort((a,b) => b.score-a.score);

const hitters = (raw.hitters || []).map(h => {
const pf = getPF(h.park);
const windScore = /out/i.test(h.wind||””) ? 8 : /in/i.test(h.wind||””) ? 3 : 5;
const parkWeather = Math.min(10, Math.max(1, (pf-0.85)*35 + windScore*0.5));
const data = { …h, parkFactor:pf, parkWeather, recentHR:5, weather:{park:h.park, wind:h.wind, temp:h.temp, factor:pf}, line:{dk:0.5,fd:0.5} };
const score = scoreHR(data);
const sim = simHR(data, 1000);
return { …data, score, sim, evDK:calcEV(sim.prob,300), evFD:calcEV(sim.prob,280), kelly:kellyCalc(sim.prob,300), verdict:hrVerdict(score) };
}).sort((a,b) => b.score-a.score);

const nrfiGames = (raw.nrfi || []).map((g,i) => ({
id:i+1, …g,
parkFactor: getPF(g.park),
yrfiHitRate: 100-(g.nrfiHitRate||52),
nrfiStreak: 0,
awayP:{name:g.awayPitcher||“TBD”,f1Era:g.awayF1ERA||3.5,f1KPct:22,hrPer9:1.0},
homeP:{name:g.homePitcher||“TBD”,f1Era:g.homeF1ERA||3.5,f1KPct:22,hrPer9:1.0},
awayTop:{name:“Lineup TBD”,obp:.320,slg:.440},
homeTop:{name:“Lineup TBD”,obp:.320,slg:.440},
hist:{nrfi:Math.round((g.nrfiHitRate||52)*2.1),total:210},
}));

return { pitchers, hitters, nrfiGames };
}

